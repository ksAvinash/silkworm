rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }
    function isSuper() {
      // token.superAdmin is the legacy claim shape, accepted during transition.
      return signedIn()
        && (request.auth.token.role == 'superadmin' || request.auth.token.superAdmin == true);
    }
    function isTenantAdmin(tenantId) {
      return signedIn() && request.auth.token.tenantId == tenantId;
    }
    function tenantActive(tenantId) {
      return get(/databases/$(database)/documents/tenants/$(tenantId)).data.status == 'active';
    }

    // Role registry, managed exclusively by Cloud Functions (Admin SDK).
    // users/{uid}: { role: superadmin | admin | farmer(later), phone, tenantId? }
    match /users/{uid} {
      allow read: if isSuper() || (signedIn() && request.auth.uid == uid);
      allow write: if false;
    }

    // Tenant metadata: the tenant's own admin may read it and bump the
    // invoice counter; only the super admin creates/manages tenants.
    match /tenants/{tenantId} {
      allow read: if isTenantAdmin(tenantId) || isSuper();
      allow create: if isSuper();
      // The tenant admin may only bump the invoice counter — never touch
      // status/name/adminPhone (no self-unsuspending).
      allow update: if isSuper()
        || (isTenantAdmin(tenantId)
            && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['invoiceSeq']));
      allow delete: if false;

      // Public invoice-verification snapshots. Direct GET by code only (the
      // code is the unguessable capability); listing is never allowed.
      match /verifications/{code} {
        allow get: if true;
        allow list: if false;
      }

      // All tenant-scoped data (breeds, batches, farmers, orders,
      // verifications) is only writable by that tenant's admin —
      // multi-tenancy enforced here. Suspended tenants keep read access
      // but cannot write anything.
      match /{subcollection}/{docId} {
        allow read: if isTenantAdmin(tenantId);
        allow write: if isTenantAdmin(tenantId) && tenantActive(tenantId);
      }
    }
  }
}
